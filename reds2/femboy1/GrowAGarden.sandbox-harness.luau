local function mkproxy(name)
  return setmetatable({}, {
    __index=function(_,k) return mkproxy(name.."."..tostring(k)) end,
    __newindex=function(_,k,v) rec("SET", name.."."..tostring(k), v) end,
    __call=function(_,...) rec("CALL", name, ...)
      if string.find(name,"HttpGet") then return "" end
